{
  "name": "mylo-debug",
  "displayName": "Mylo Debugger",
  "version": "0.1.14",
  "publisher": "mylo-lang",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Debuggers",
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mylo",
        "aliases": ["Mylo", "mylo"],
        "extensions": [".mylo"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [{
        "language": "mylo",
        "scopeName": "source.mylo",
        "path": "./syntaxes/mylo.tmLanguage.json"
    }],
    "breakpoints": [
      {
        "language": "mylo"
      }
    ],
    "debuggers": [
      {
        "type": "mylo",
        "label": "Mylo Debug",
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to a mylo file",
                "default": "${file}"
                },
              "cwd": {
                "type": "string",
                "description": "Program working directory",
                "default": "${workspaceFolder}"
              },
              "env": {
                "type": "object",
                "description": "Environment variables to pass to the program",
                "default": {}
                }
            }
          }
        }
      }
    ],
    "commands": [
      {
        "command": "mylo.initProject",
        "title": "Mylo: Init Project"
      }
    ]
  },
  "activationEvents": [
    "onDebugResolve:mylo",
    "onLanguage:mylo",
    "onCommand:mylo.initProject"
  ],
  "main": "./extension.js",
  "scripts": {
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.60.0",
    "@vscode/vsce": "^2.31.1"
  }
}
